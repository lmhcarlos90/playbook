#!/bin/bash
# Spring Boot 停止脚本

PID=$(pgrep -f {{ jar_file }})

if [ -z "$PID" ]; then
    echo "应用未运行"
else
    echo "正在停止应用 (PID: $PID)..."
    kill $PID
    sleep 5

    # 如果还没停就强制杀
    if pgrep -f {{ jar_file }} > /dev/null; then
        echo "强制停止..."
        kill -9 $PID
    fi
    echo "应用已停止"
fi